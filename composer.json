{
    "name": "novius/laravel-nova-translation",
    "description": "A Nova tool to manage application's translations.",
    "keywords": [
        "laravel",
        "nova",
        "language",
        "translation",
        "i18n"
    ],
    "license": "AGPL-3.0-or-later",
    "require": {
        "php": ">=8.1",
        "laravel/nova": "~4.0|~5.0",
        "novius/laravel-translation-loader": "dev-feature/dirty"
    },
    "require-dev": {
        "larastan/larastan": "^v2.9|^3.1",
        "laravel/pint": "^v1.21.0",
        "orchestra/testbench": "^8.0|^9.0|^v10.0"
    },
    "autoload": {
        "psr-4": {
            "Novius\\LaravelNovaTranslation\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Novius\\LaravelNovaTranslation\\LaravelNovaTranslationServiceProvider"
            ]
        }
    },
    "scripts": {
        "cs-fix": [
            "./vendor/bin/pint -v"
        ],
        "lint": [
            "@composer cs-fix -- --test"
        ],
        "phpstan": [
            "vendor/bin/phpstan analyse -c phpstan.neon --memory-limit 1G"
        ],
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ]
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://nova.laravel.com"
        }
    ],
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload-dev": {
        "psr-4": {
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        }
    }
}
